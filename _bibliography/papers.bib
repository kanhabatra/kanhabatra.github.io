@article{padillacoreano2022cortical,
  abbr        = {Nature},
  bibtex_show = {true},
  title       = {Cortical ensembles orchestrate social competition through hypothalamic outputs},
  author      = {Padilla-Coreano*, Nancy and Batra*, Kanha and Patarino, Makenzie and Chen, Zexin and
                 Rock, Rachel R. and Zhang, Ruihan and Hausmann, S\'{e}bastien B. and
                 Weddington, Javier C. and Patel, Reesha R. and Zhang, Yu E. and Fang, Hao-Shu and
                 Mishra, Srishti and LeDuke, Deryn O. and Revanna, Jasmin and Li, Hao and
                 Borio, Matilde and Pamintuan, Rachelle and Bal, Aneesh and Keyes, Laurel R. and
                 Libster, Avraham and Wichmann, Romy and Mills, Fergil and Taschbach, Felix H. and
                 Matthews, Gillian A. and Curley, James P. and Fiete, Ila R. and Lu, Cewu and
                 Tye, Kay M.},
  journal     = {Nature},
  year        = {2022},
  note        = {*co-first authors},
  selected    = {true},
  abstract    = {Social hierarchies profoundly shape behavior in group-living animals, yet the neural
                 mechanisms by which the brain computes and updates social rank remain poorly
                 understood. Here we identify cortical ensemble dynamics in the medial prefrontal
                 cortex (mPFC) that encode social dominance and drive competitive behavior through
                 projections to the lateral hypothalamus. We developed an unsupervised HMM-GLM
                 framework that models mPFC internal states and predicts behavioral motifs during
                 competition with high accuracy (ROC-AUC ~0.92).},
  html        = {https://www.nature.com/articles/s41586-022-04507-5},
  doi         = {10.1038/s41586-022-04507-5},
}

@article{li2022neurotensin,
  abbr        = {Nature},
  bibtex_show = {true},
  title       = {Neurotensin orchestrates valence assignment in the amygdala},
  author      = {Li*, Hao and Namburi*, Praneeth and Olson, Jacob M. and Borio, Matilde and
                 Lemieux, Mackenzie E. and Beyeler, Anna and Calhoon, Gwendolyn G. and
                 Hitora-Imamura, Natsuko and Coley, Austin A. and Libster, Avraham and
                 Bal, Aneesh and Jin, Xin and Wang, Huan and Jia, Caroline and
                 Choudhury, Sourav R. and Shi, Xi and Felix-Ortiz, Ada C. and
                 de la Fuente, Ver\'{o}nica and Barth, Vanessa P. and King, Hunter O. and
                 Izadmehr, Ehsan M. and Revanna, Jasmin S. and Batra, Kanha and
                 Fischer, Kyle B. and Keyes, Laurel R. and Padilla-Coreano, Nancy and
                 Siciliano, Cody A. and McCullogh, Kenneth M. and Wichmann, Romy and
                 Ressler, Kerry J. and Fiete, Ila R. and Zhang, Feng and Li, Yulong and
                 Tye, Kay M.},
  journal     = {Nature},
  year        = {2022},
  note        = {*co-first authors},
  selected    = {true},
  abstract    = {Neurotensin (NT) is a neuropeptide implicated in the modulation of dopaminergic
                 and reward circuits. Here we show that NT release in the basolateral amygdala
                 orchestrates valence assignment by coordinating activity across distinct cell
                 populations, linking neuromodulatory signals to the encoding of positive and
                 negative emotional valence.},
  html        = {https://www.nature.com/articles/s41586-022-04964-y},
  doi         = {10.1038/s41586-022-04964-y},
}

@article{leppla2023thalamus,
  abbr        = {Psychopharm.},
  bibtex_show = {true},
  title       = {Thalamus sends information about arousal but not valence to the amygdala},
  author      = {Leppla, Chris A. and Keyes, Laurel R. and Glober, Gordon and Matthews, Gillian A.
                 and Batra, Kanha and Jay, Maya and Feng, Yu and Chen, Hannah S. and Mills, Fergil
                 and Delahanty, Jeremy M. and Olsen, Jacob M. and Nieh, Edward H. and
                 Namburi, Praneeth and Wildes, Craig and Wichmann, Romy and Beyeler, Anna and
                 Kimchi, Eyal Y. and Tye, Kay M.},
  journal     = {Psychopharmacology},
  year        = {2023},
  selected    = {false},
  abstract    = {The thalamus is a key relay for sensory and affective information. Here we
                 dissociate the contributions of thalamic projections to the amygdala, demonstrating
                 that the thalamus encodes and transmits arousal signals but does not carry
                 valence-specific information to amygdala circuits.},
  html        = {https://link.springer.com/article/10.1007/s00213-023-06358-0},
  doi         = {10.1007/s00213-023-06358-0},
}

@article{digma2022correcting,
  abbr        = {Sci. Rep.},
  bibtex_show = {true},
  title       = {Correcting B0 inhomogeneity-induced distortions in whole-body diffusion {MRI} of
                 bone metastases},
  author      = {Digma, Leonardino A. and Feng, Christine H. and Conlin, Christopher C. and
