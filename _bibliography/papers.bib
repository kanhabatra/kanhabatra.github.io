@article{padillacoreano2022cortical,
  abbr        = {Nature},
  bibtex_show = {true},
  title       = {Cortical ensembles orchestrate social competition through hypothalamic outputs},
  author      = {Padilla-Coreano, Nancy and Batra, Kanha and Patarino, Makenzie and Chen, Zexin and
                 Rock, Rachel R. and Zhang, Ruihan and Hausmann, S\'{e}bastien B. and
                 Weddington, Javier C. and Patel, Reesha R. and Zhang, Yu E. and Fang, Hao-Shu and
                 Mishra, Srishti and LeDuke, Deryn O. and Revanna, Jasmin and Li, Hao and
                 Borio, Matilde and Pamintuan, Rachelle and Bal, Aneesh and Keyes, Laurel R. and
                 Libster, Avraham and Wichmann, Romy and Mills, Fergil and Taschbach, Felix H. and
                 Matthews, Gillian A. and Curley, James P. and Fiete, Ila R. and Lu, Cewu and
                 Tye, Kay M.},
  journal     = {Nature},
  year        = {2022},
  note        = {*co-first authors},
  selected    = {true},
  abstract    = {Social hierarchies profoundly shape behavior in group-living animals, yet the neural
                 mechanisms by which the brain computes and updates social rank remain poorly
                 understood. Here we identify cortical ensemble dynamics in the medial prefrontal
                 cortex (mPFC) that encode social dominance and drive competitive behavior through
                 projections to the lateral hypothalamus.},
  html        = {https://www.nature.com/articles/s41586-022-04507-5},
}

@article{li2022neurotensin,
  abbr        = {Nature},
  bibtex_show = {true},
  title       = {Neurotensin orchestrates valence assignment in the amygdala},
  author      = {Li, Hao and Namburi, Praneeth and Olson, Jacob M. and Borio, Matilde and
                 Lemieux, Mackenzie E. and Beyeler, Anna and Calhoon, Gwendolyn G. and
                 Hitora-Imamura, Natsuko and Coley, Austin A. and Libster, Avraham and
                 Bal, Aneesh and Jin, Xin and Wang, Huan and Jia, Caroline and
                 Choudhury, Sourav R. and Shi, Xi and Felix-Ortiz, Ada C. and
                 de la Fuente, Ver\'{o}nica and Barth, Vanessa P. and King, Hunter O. and
                 Izadmehr, Ehsan M. and Revanna, Jasmin S. and Batra, Kanha and
                 Fischer, Kyle B. and Keyes, Laurel R. and Padilla-Coreano, Nancy and
                 Siciliano, Cody A. and McCullogh, Kenneth M. and Wichmann, Romy and
                 Ressler, Kerry J. and Fiete, Ila R. and Zhang, Feng and Li, Yulong and
                 Tye, Kay M.},
  journal     = {Nature},
  year        = {2022},
  note        = {*co-first authors},
  selected    = {true},
  abstract    = {Neurotensin (NT) is a neuropeptide that has been implicated in the modulation of
                 dopaminergic and other reward circuits, but its role in assigning emotional valence
                 in the amygdala has not been established. Here we show that NT release in the
                 basolateral amygdala orchestrates valence assignment by coordinating activity across
                 distinct cell populations.},
  html        = {https://www.nature.com/articles/s41586-022-04964-y},
}

