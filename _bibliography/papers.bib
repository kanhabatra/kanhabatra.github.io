@article{coley2024predicting,
  abbr        = {Preprint},
  bibtex_show = {true},
  title       = {Predicting Future Development of Stress-Induced Anhedonia From Cortical Dynamics
                 and Facial Expression},
  author      = {Coley, Austin A. and Batra, Kanha and Delahanty, Jeremy M. and Keyes, Laurel R. and
                 Pamintuan, Rachelle and Ramot, Assaf and Hagemann, Jim and Lee, Christopher R. and
                 Liu, Vivian and Adivikolanu, Harini and Cressy, Jianna and Jia, Caroline and
                 Massa, Francesca and LeDuke, Deryn O. and Gabir, Moumen and Durubeh, Bra{'}a and
                 Linderhof, Lexe and Patel, Reesha R. and Wichmann, Romy and Li, Hao and
                 Fischer, Kyle B. and Pereira, Talmo D. and Tye, Kay M.},
  journal     = {bioRxiv},
  year        = {2024},
  selected    = {false},
  abstract    = {Stress-induced anhedonia is a core feature of depression, yet predicting which
                 individuals will develop it remains an open challenge. By combining cortical
                 population dynamics with automated facial expression analysis, we demonstrate
                 that future development of anhedonia can be predicted from baseline neural and
                 behavioral features, opening avenues for early intervention.},
  html        = {https://www.biorxiv.org/content/10.1101/2024.02.01.578472},
  arxiv       = {2024.02.01.578472},
}

@article{patel2024social,
  abbr        = {Preprint},
  bibtex_show = {true},
  title       = {Social isolation recruits amygdala-cortical circuitry to escalate alcohol drinking},
  author      = {Patel, Reesha R. and Patarino, Makenzie and Kim, Kelly N. and Pamintuan, Rachelle
                 and Taschbach, Felix H. and Li, Hao and Lee, Christopher R. and van Hoek, Aniek and
                 Castro, Rogelio and Cazares, Christian and Miranda, Raymundo L. and Jia, Caroline and
                 Delahanty, Jeremy M. and Batra, Kanha and Keyes, Laurel R. and Libster, Avraham and
                 Wichmann, Romy and Pereira, Talmo D. and Benna, Marcus K. and Tye, Kay M.},
  journal     = {bioRxiv},
  year        = {2024},
  selected    = {false},
  abstract    = {Social isolation is a potent driver of escalated alcohol consumption, but the
                 underlying neural mechanisms are poorly understood. We identify an amygdala-cortical
                 circuit recruited by social isolation that gates escalated alcohol drinking,
                 providing mechanistic insight into the neural basis of isolation-induced substance use.},
  html        = {https://www.biorxiv.org/content/10.1101/2024.02.12.579910},
  arxiv       = {2024.02.12.579910},
}

