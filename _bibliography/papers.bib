%% ============================================================
%% papers.bib — Kanha Batra
%%
%% HOW TO ADD A PAPER
%% ------------------
%% 1. Go to Google Scholar / PubMed / arXiv and find the BibTeX
%%    for your paper (usually under "Cite" → "BibTeX").
%% 2. Paste the entry below.
%% 3. Add any of these optional al-folio fields inside the entry:
%%      selected  = {true}           — shows on homepage
%%      abstract  = {Your abstract}  — adds an expandable abstract
%%      pdf       = {paper.pdf}      — links to a PDF in assets/pdf/
%%      html      = {https://...}    — link to paper page
%%      arxiv     = {2401.00000}     — links to arXiv
%%      code      = {https://github.com/...}
%%      poster    = {poster.pdf}
%%      slides    = {slides.pdf}
%%      google_scholar_id = {XXXXXX} — enables Scholar citation badge
%%      preview   = {paper_thumb.png} — thumbnail image in assets/img/
%%
%% EXAMPLE ENTRY (rename/replace with your actual papers):
%% ============================================================

@article{batra2024example,
  abbr        = {J. Neurosci.},
  bibtex_show = {true},
  title       = {[Your Paper Title Here]},
  author      = {Batra, Kanha and [Co-author 1] and [Co-author 2]},
  journal     = {[Journal Name]},
  year        = {2024},
  abstract    = {[Paste your abstract here]},
  selected    = {true},
  % pdf       = {batra2024example.pdf},
  % html      = {https://doi.org/...},
  % arxiv     = {2401.00000},
  % code      = {https://github.com/kanhabatra/...},
}

