@inproceedings{batra2024cosyne_nmoe,
  abbr        = {Cosyne},
  bibtex_show = {true},
  title       = {Neuromodulated mixture of experts: A prefrontal cortex inspired architecture
                 for lifelong learning},
  author      = {Batra, Kanha and Bakhti-Suroosh, Anousheh and Yi, Clara N. and Chan, May G. and
                 Tseng, Ruby and Banducci, Kelbi and Zhang, Jiaqi and Lee, Christopher R. and
                 Roy, Tanisha and Chang, Kelly and Wichmann, Romy and Jia, Caroline and
                 Tsuda, Ben and Nielsen, Bryan and Keyes, Laurel R. and Tuazon, Tristan B. and
                 Pereira, Talmo D. and Sejnowski, Terrence J. and Tye, Kay M.},
  booktitle   = {Computational \& Systems Neuroscience (Cosyne)},
  year        = {2024},
  address     = {Lisbon, Portugal},
  month       = {March},
  selected    = {false},
  abstract    = {We propose a Neuromodulated Mixture of Experts (NMoE) architecture inspired by
                 the role of neuromodulation in the prefrontal cortex. The model uses gating
                 signals analogous to neuromodulatory inputs to selectively engage expert
                 sub-networks, enabling flexible, context-dependent computation and continual
                 learning without catastrophic forgetting.},
}

